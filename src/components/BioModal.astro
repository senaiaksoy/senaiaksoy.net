    <a href="https://orcid.org/my-orcid?orcid=0000-0003-4110-5290" target="_blank" rel="noopener">
      <img src="https://img.shields.io/badge/ORCID-A6CE39?style=for-the-badge&logo=orcid&logoColor=white" alt="ORCID" />
    </a>
    <a href="https://scholar.google.com/scholar?hl=tr&as_sdt=0%2C5&q=senai+aksoy&oq=" target="_blank" rel="noopener">
      <img src="https://img.shields.io/badge/Google_Scholar-4285F4?style=for-the-badge&logo=googlescholar&logoColor=white" alt="Google Scholar" />
    </a>
    <a href="https://amerikanhastanesi.academia.edu/SenaiAksoy" target="_blank" rel="noopener">
      <img src="https://img.shields.io/badge/Academia.edu-41454A?style=for-the-badge&logo=academia&logoColor=white" alt="Academia" />

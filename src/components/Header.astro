---
const pathname = Astro.url.pathname;
---

<header class="site-header">
  <div class="inner">
    <a href="/" class="logo-link">
      <img src="/theme/logo.png" alt="Dr. Senai Aksoy" />
    </a>
    <nav class="site-nav">
      <a href="/" class:list={[{ active: pathname === '/' }]}>Ana Sayfa</a>
      <a href="/contact" class:list={[{ active: pathname.startsWith('/contact') }]}>İletişim</a>
      <span class="nav-divider"></span>
      <a href="https://draksoyivf.com" class="intl-patients-link" target="_blank" rel="noopener" lang="en">
        For International Patients →
      </a>
    </nav>
  </div>
</header>
